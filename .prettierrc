{
    "plugins": ["@trivago/prettier-plugin-sort-imports"],
    "semi": true,
    "singleQuote": false,
    "tabWidth": 4,
    "trailingComma": "all",
    "bracketSpacing": false,
    "printWidth": 120,
    "importOrder": ["^aws-cdk.*$", "^[./]"],
    "importOrderSeparation": true,
    "importOrderSortSpecifiers": true
}
